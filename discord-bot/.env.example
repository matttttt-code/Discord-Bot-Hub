# ==============================
# CONNEXION BOT — Configuration
# ==============================

# Token Discord de ton bot (OBLIGATOIRE)
# 1. Va sur https://discord.com/developers/applications
# 2. Crée une nouvelle application ou sélectionne la tienne
# 3. Onglet "Bot" → "Reset Token" → Copie le token
DISCORD_TOKEN=ton_token_ici

# Préfixe des commandes (défaut: !)
PREFIX=!

# Nom affiché du bot
BOT_NAME=CONNEXION BOT

# ==============================
# RÔLES (optionnel si tu utilises !setup)
# Ces variables sont des FALLBACK si !setup n'a pas encore configuré les rôles
# ==============================

# Rôle Tier 2 — Administration (ID du rôle)
TIER2_ROLE_ID=

# Rôle Tier 3 — Gérant (ID du rôle)
TIER3_ROLE_ID=

# ==============================
# CHANNELS (optionnel si tu utilises !setup)
# ==============================

# Channel où envoyer les suggestions (!suggestion)
SUGGESTIONS_CHANNEL_ID=

# Channel où envoyer les signalements (!support)
SUPPORT_CHANNEL_ID=

# ==============================
# BASE DE DONNÉES
# ==============================

# Chemin du dossier de données SQLite (défaut: ./data)
DB_PATH=./data
